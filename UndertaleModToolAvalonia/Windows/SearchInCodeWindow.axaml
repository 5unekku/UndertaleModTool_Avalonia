<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UndertaleModTool"
        x:Class="UndertaleModTool.Windows.SearchInCodeWindow"
        mc:Ignorable="d"
        Title="Search in code" Height="500" Width="800" WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Padding="6,2" Background="#20808080">
            <TextBlock Name="StatusBarTextBlock" />
        </Border>
        <Grid Margin="10" RowDefinitions="Auto,Auto,Auto,*">
            <local:TextBoxDark x:Name="SearchTextBox" Grid.Row="0" TextWrapping="Wrap" AcceptsReturn="True" Height="36" VerticalAlignment="Top" KeyDown="SearchTextBox_KeyDown" />
            <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,5,0,0">
                <CheckBox Name="CaseSensitiveCheckBox" Content="Case sensitive" Margin="0,0,5,0" />
                <CheckBox Name="RegexSearchCheckBox" Content="Regex search" Margin="0,0,5,0" />
                <CheckBox Name="MultilineRegexCheckBox" Content="Multiline regex" Margin="0,0,5,0" IsVisible="{Binding #RegexSearchCheckBox.IsChecked}" />
                <CheckBox Name="InAssemblyCheckBox" Content="In assembly" Margin="0,0,12,0" />
            </StackPanel>
            <local:ButtonDark x:Name="SearchButton" Grid.Row="1" Content="Search" Width="68" Margin="0,5,0,0" FontSize="14" Click="SearchButton_Click" HorizontalAlignment="Right" IsDefault="True" />

            <Expander Name="FilterByNameExpander" Grid.Row="2" Margin="0,0,0,6" Header="Filter by code name" IsExpanded="False">
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <local:TextBoxDark x:Name="NameFilterTextBox" AcceptsReturn="False" Width="280" HorizontalAlignment="Left" Margin="0,0,10,0" />
                    <CheckBox Name="NameCaseSensitiveCheckBox" Content="Case sensitive" Margin="0,0,5,0" />
                    <CheckBox Name="NameRegexSearchCheckBox" Content="Regex search" Margin="0,0,5,0" />
                </StackPanel>
            </Expander>

            <DataGrid x:Name="ResultsListView" Grid.Row="3" ItemsSource="{Binding Results}" IsReadOnly="True"
                      FontFamily="Consolas" SelectionMode="Extended" DoubleTapped="ResultsListView_DoubleTapped">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="Auto" />
                    <DataGridTextColumn Header="Line" Binding="{Binding LineNumber}" Width="Auto" />
                    <DataGridTextColumn Header="Text" Binding="{Binding LineText}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</Window>
