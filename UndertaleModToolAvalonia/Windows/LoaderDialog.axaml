<Window x:Class="UndertaleModTool.LoaderDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UndertaleModTool"
        mc:Ignorable="d"
        Height="150" Width="400" WindowStartupLocation="CenterOwner" CanResize="False">
    <Grid Margin="10" RowDefinitions="*,*,*">
        <TextBlock Grid.Row="0" VerticalAlignment="Center" x:Name="MessageText" />
        <ProgressBar Grid.Row="1" IsIndeterminate="True" Name="ProgressBar" />
        <TextBlock Grid.Row="2" VerticalAlignment="Center" x:Name="StatusTextBlock" />
    </Grid>
</Window>
