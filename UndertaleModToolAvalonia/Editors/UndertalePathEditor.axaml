<local:DataUserControl x:Class="UndertaleModTool.UndertalePathEditor"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:UndertaleModTool"
             xmlns:undertale="clr-namespace:UndertaleModLib.Models;assembly=UndertaleModLib"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <local:PointsDisplayConverter x:Key="PointsDisplayConverter" />
    </UserControl.Resources>

    <Grid ColumnDefinitions="1*,3*">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="3" Text="Name" />
        <local:UndertaleStringReference Grid.Row="0" Grid.Column="1" Margin="3" ObjectReference="{Binding Name}" />

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="3" Text="Smooth" />
        <CheckBox Grid.Row="1" Grid.Column="1" Margin="3" IsChecked="{Binding IsSmooth}" />

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="3" Text="Closed" />
        <CheckBox Grid.Row="2" Grid.Column="1" Margin="3" IsChecked="{Binding IsClosed}" />

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="3" Text="Precision" />
        <local:TextBoxDark Grid.Row="3" Grid.Column="1" Margin="3" Text="{Binding Precision}" />

        <TextBlock Grid.Row="4" Grid.Column="0" Margin="3" Text="Points" />
        <DockPanel Grid.Row="4" Grid.Column="1" Margin="3">
            <local:ButtonDark DockPanel.Dock="Bottom" HorizontalAlignment="Left" Margin="0,3,0,0" Content="Add" Click="Add_Click" />
            <local:EditableDataGridDark ItemsSource="{Binding Points}" AutoGenerateColumns="False" x:Name="PointsGrid"
                                        HeadersVisibility="Column" GridLinesVisibility="All" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="X" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <local:TextBoxDark Text="{Binding X, Mode=TwoWay}" Margin="20,0,0,0" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Y" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <local:TextBoxDark Text="{Binding Y, Mode=TwoWay}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Speed" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <local:TextBoxDark Text="{Binding Speed, Mode=TwoWay}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </local:EditableDataGridDark>
        </DockPanel>

        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2">
            <TextBlock Foreground="DarkGray" FontStyle="Italic" Text="TODO: The preview doesn't update live, I know, just close and reopen the object for now" />
        </StackPanel>

        <Viewbox Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Width="300" Height="300">
            <Path Stroke="Green" StrokeThickness="2" Stretch="Fill"
                  Data="{Binding ., Converter={StaticResource PointsDisplayConverter}}" />
        </Viewbox>
    </Grid>
</local:DataUserControl>
