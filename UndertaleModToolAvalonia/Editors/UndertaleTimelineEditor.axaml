<local:DataUserControl x:Class="UndertaleModTool.UndertaleTimelineEditor"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:UndertaleModTool"
             xmlns:undertale="clr-namespace:UndertaleModLib.Models;assembly=UndertaleModLib"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="3" Text="Name" />
        <local:UndertaleStringReference Grid.Row="0" Grid.Column="1" Margin="3" ObjectReference="{Binding Name}" />

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="3" Text="Moments" />
        <DockPanel Grid.Row="3" Grid.Column="1" Margin="3">
            <local:ButtonDark DockPanel.Dock="Bottom" HorizontalAlignment="Left" Margin="0,3,0,0" Content="Add" Click="Add_Click" />
            <local:EditableDataGridDark x:Name="MomentsGrid" ItemsSource="{Binding Moments}"
                                        AutoGenerateColumns="False" HeadersVisibility="Column"
                                        GridLinesVisibility="All" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Step" Width="1*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <local:TextBoxDark Text="{Binding Step, Mode=TwoWay}" Margin="20,0,0,0" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Actions (Code Entries)" Width="3*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <local:EditableDataGridDark ItemsSource="{Binding Event}" AutoGenerateColumns="False"
                                                            HeadersVisibility="None" GridLinesVisibility="All" SelectionMode="Single">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Code" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <local:UndertaleObjectReference ObjectReference="{Binding CodeId, Mode=TwoWay}"
                                                                                    ObjectType="{x:Type undertale:UndertaleCode}" Margin="23,3,3,3" CanRemove="False" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </local:EditableDataGridDark>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </local:EditableDataGridDark>
        </DockPanel>
    </Grid>
</local:DataUserControl>
