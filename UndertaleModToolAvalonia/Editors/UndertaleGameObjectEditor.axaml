<local:DataUserControl x:Class="UndertaleModTool.UndertaleGameObjectEditor"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:UndertaleModTool"
             xmlns:undertale="clr-namespace:UndertaleModLib.Models;assembly=UndertaleModLib"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <local:EventNameConverter x:Key="EventNameConverter" />
            <local:GameObjectByIdConverter x:Key="GameObjectByIdConverter" />
            <local:IsGMS2Converter x:Key="IsGMS2Converter" />
            <local:EventEditorVisibleConverter x:Key="EventEditorVisibleConverter" />
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Controls/TransparencyGridBrush.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>
        <Grid ColumnDefinitions="1*,3*">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="3" Text="Name" />
            <local:UndertaleStringReference Grid.Row="0" Grid.Column="1" Margin="3" ObjectReference="{Binding Name}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="3" Text="Sprite" />
            <local:UndertaleObjectReference Grid.Row="1" Grid.Column="1" Margin="3" ObjectReference="{Binding Sprite}" ObjectType="{x:Type undertale:UndertaleSprite}" />

            <ListBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding Sprite.Textures, Mode=OneWay}" Background="Transparent" BorderThickness="0">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                            <Border Background="{DynamicResource TransparencyGridBrushBrush}">
                                <local:UndertaleTexturePageItemDisplay DataContext="{Binding Texture, Mode=OneWay}" />
                            </Border>
                        </Viewbox>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Grid.Row="3" Grid.Column="0" Margin="3" Text="Visible" />
            <CheckBox Grid.Row="3" Grid.Column="1" Margin="3" IsChecked="{Binding Visible}" />

            <TextBlock Grid.Row="4" Grid.Column="0" Margin="3" Text="Solid" />
            <CheckBox Grid.Row="4" Grid.Column="1" Margin="3" IsChecked="{Binding Solid}" />

            <TextBlock Grid.Row="5" Grid.Column="0" Margin="3" Text="Depth"
                       IsVisible="{Binding DataContext.IsGMS2, Mode=OneTime, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}, Converter={StaticResource IsGMS2Converter}}" />
            <local:TextBoxDark Grid.Row="5" Grid.Column="1" Margin="3" Text="{Binding Depth}"
                       IsVisible="{Binding DataContext.IsGMS2, Mode=OneTime, RelativeSource={RelativeSource AncestorType={x:Type local:MainWindow}}, Converter={StaticResource IsGMS2Converter}}" />

            <TextBlock Grid.Row="6" Grid.Column="0" Margin="3" Text="Persistent" />
            <CheckBox Grid.Row="6" Grid.Column="1" Margin="3" IsChecked="{Binding Persistent}" />

            <TextBlock Grid.Row="7" Grid.Column="0" Margin="3" Text="Parent" />
            <local:UndertaleObjectReference Grid.Row="7" Grid.Column="1" Margin="3" ObjectReference="{Binding ParentId}" ObjectType="{x:Type undertale:UndertaleGameObject}" />

            <TextBlock Grid.Row="8" Grid.Column="0" Margin="3" Text="Texture mask id" />
            <local:UndertaleObjectReference Grid.Row="8" Grid.Column="1" Margin="3" ObjectReference="{Binding TextureMaskId}" ObjectType="{x:Type undertale:UndertaleSprite}" />

            <TextBlock Grid.Row="9" Grid.Column="0" Margin="3" Text="Uses physics" />
            <CheckBox Grid.Row="9" Grid.Column="1" Margin="3" IsChecked="{Binding UsesPhysics}" />

            <TextBlock Grid.Row="10" Grid.Column="0" Margin="3" Text="Is sensor" />
            <CheckBox Grid.Row="10" Grid.Column="1" Margin="3" IsChecked="{Binding IsSensor}" />

            <TextBlock Grid.Row="11" Grid.Column="0" Margin="3" Text="Collision shape" />
            <local:ComboBoxDark Grid.Row="11" Grid.Column="1" Margin="3" ItemsSource="{local:EnumValues undertale:CollisionShapeFlags}" SelectedItem="{Binding CollisionShape}" />

            <Separator Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2" />

            <TextBlock Grid.Row="13" Grid.Column="0" Margin="3" FontWeight="Bold" Text="Physics" />

            <TextBlock Grid.Row="14" Grid.Column="0" Margin="3" Text="Density" />
            <local:TextBoxDark Grid.Row="14" Grid.Column="1" Margin="3" Text="{Binding Density}" />

            <TextBlock Grid.Row="15" Grid.Column="0" Margin="3" Text="Restitution" />
            <local:TextBoxDark Grid.Row="15" Grid.Column="1" Margin="3" Text="{Binding Restitution}" />

            <TextBlock Grid.Row="16" Grid.Column="0" Margin="3" Text="Group" />
            <local:TextBoxDark Grid.Row="16" Grid.Column="1" Margin="3" Text="{Binding Group}" />

            <TextBlock Grid.Row="17" Grid.Column="0" Margin="3" Text="Linear damping" />
            <local:TextBoxDark Grid.Row="17" Grid.Column="1" Margin="3" Text="{Binding LinearDamping}" />

            <TextBlock Grid.Row="18" Grid.Column="0" Margin="3" Text="Angular damping" />
            <local:TextBoxDark Grid.Row="18" Grid.Column="1" Margin="3" Text="{Binding AngularDamping}" />

            <TextBlock Grid.Row="19" Grid.Column="0" Margin="3" Text="Friction" />
            <local:TextBoxDark Grid.Row="19" Grid.Column="1" Margin="3" Text="{Binding Friction}" />

            <TextBlock Grid.Row="20" Grid.Column="0" Margin="3" Text="Is awake" />
            <CheckBox Grid.Row="20" Grid.Column="1" Margin="3" IsChecked="{Binding Awake}" />

            <TextBlock Grid.Row="21" Grid.Column="0" Margin="3" Text="Is kinematic" />
            <CheckBox Grid.Row="21" Grid.Column="1" Margin="3" IsChecked="{Binding Kinematic}" />

            <TextBlock Grid.Row="22" Grid.Column="0" Margin="3" Text="Physics shape vertices" />
            <DockPanel Grid.Row="22" Grid.Column="1" Margin="3">
                <local:ButtonDark DockPanel.Dock="Bottom" HorizontalAlignment="Left" Margin="0,3,0,0" Content="Add" Click="AddPhysicsVertex_Click" />
                <local:EditableDataGridDark x:Name="PhysicsVerticesGrid" ItemsSource="{Binding PhysicsVertices, Mode=OneWay}"
                                            AutoGenerateColumns="False" HeadersVisibility="Column" GridLinesVisibility="All" SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="X" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <local:TextBoxDark Text="{Binding X, Mode=TwoWay}" Margin="20,0,0,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Y" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <local:TextBoxDark Text="{Binding Y, Mode=TwoWay}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </local:EditableDataGridDark>
            </DockPanel>

            <Separator Grid.Row="23" Grid.Column="0" Grid.ColumnSpan="2" />
        </Grid>

        <TextBlock Margin="3" FontWeight="Bold" Text="Events" />

        <ItemsControl x:Name="EventsItemsControl">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Margin="3" Text="{Binding TypeName}" />
                        <local:ButtonDark HorizontalAlignment="Left" Margin="3,0" Content="Add event" Click="AddEvent_Click" />
                        <local:EditableDataGridDark ItemsSource="{Binding Events}" AutoGenerateColumns="False"
                                                    HeadersVisibility="Column" GridLinesVisibility="All" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Subtype ID" Width="1*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Panel Margin="3">
                                                <!-- key (KeyPress/KeyRelease/Keyboard) -->
                                                <StackPanel IsVisible="{Binding DataContext.TypeName, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource EventEditorVisibleConverter}, ConverterParameter=key}">
                                                    <local:ComboBoxDark ItemsSource="{local:EnumValues undertale:EventSubtypeKey}" SelectedItem="{Binding EventSubtypeKey, Mode=TwoWay}" />
                                                    <local:TextBoxDark Text="{Binding EventSubtype, Mode=TwoWay}" />
                                                </StackPanel>
                                                <local:ComboBoxDark IsVisible="{Binding DataContext.TypeName, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource EventEditorVisibleConverter}, ConverterParameter=step}"
                                                                    ItemsSource="{local:EnumValues undertale:EventSubtypeStep}" SelectedItem="{Binding EventSubtypeStep, Mode=TwoWay}" />
                                                <local:ComboBoxDark IsVisible="{Binding DataContext.TypeName, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource EventEditorVisibleConverter}, ConverterParameter=mouse}"
                                                                    ItemsSource="{local:EnumValues undertale:EventSubtypeMouse}" SelectedItem="{Binding EventSubtypeMouse, Mode=TwoWay}" />
                                                <local:ComboBoxDark IsVisible="{Binding DataContext.TypeName, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource EventEditorVisibleConverter}, ConverterParameter=other}"
                                                                    ItemsSource="{local:EnumValues undertale:EventSubtypeOther}" SelectedItem="{Binding EventSubtypeOther, Mode=TwoWay}" />
                                                <local:ComboBoxDark IsVisible="{Binding DataContext.TypeName, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource EventEditorVisibleConverter}, ConverterParameter=draw}"
                                                                    ItemsSource="{local:EnumValues undertale:EventSubtypeDraw}" SelectedItem="{Binding EventSubtypeDraw, Mode=TwoWay}" />
                                                <local:UndertaleObjectReference IsVisible="{Binding DataContext.TypeName, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource EventEditorVisibleConverter}, ConverterParameter=collision}"
                                                                    ObjectReference="{Binding EventSubtype, Converter={StaticResource GameObjectByIdConverter}, Mode=TwoWay}" ObjectType="{x:Type undertale:UndertaleGameObject}" CanRemove="False" />
                                                <TextBlock TextAlignment="Center" Text="n/a" IsVisible="{Binding DataContext.TypeName, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource EventEditorVisibleConverter}, ConverterParameter=none}" />
                                                <local:TextBoxDark Text="{Binding EventSubtype, Mode=TwoWay}" IsVisible="{Binding DataContext.TypeName, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource EventEditorVisibleConverter}, ConverterParameter=raw}" />
                                            </Panel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Actions" Width="5*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <local:ButtonDark HorizontalAlignment="Left" Margin="3,0" Content="Add action" Click="AddAction_Click" />
                                                <local:EditableDataGridDark ItemsSource="{Binding Actions}" AutoGenerateColumns="False"
                                                                            HeadersVisibility="None" GridLinesVisibility="All" SelectionMode="Single">
                                                    <DataGrid.Columns>
                                                        <DataGridTemplateColumn Header="Code" Width="*">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <local:UndertaleObjectReference ObjectReference="{Binding CodeId, Mode=TwoWay}" ObjectType="{x:Type undertale:UndertaleCode}"
                                                                                                    ObjectReferenceChanged="UndertaleObjectReference_ObjectReferenceChanged_ActionCode"
                                                                                                    Margin="23,3,3,3" CanRemove="False" Loaded="UndertaleObjectReference_Loaded"
                                                                                                    GameObject="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type local:DataUserControl}}}"
                                                                                                    ObjectEventType="{Binding DataContext.EventType, RelativeSource={RelativeSource AncestorType=DataGrid, AncestorLevel=2}}"
                                                                                                    ObjectEventSubtype="{Binding DataContext.EventSubtype, Mode=OneWay, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                    </DataGrid.Columns>
                                                </local:EditableDataGridDark>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </local:EditableDataGridDark>
                        <Separator />
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</local:DataUserControl>
