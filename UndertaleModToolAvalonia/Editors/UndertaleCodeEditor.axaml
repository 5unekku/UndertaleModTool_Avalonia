<local:DataUserControl x:Class="UndertaleModTool.UndertaleCodeEditor"
                       xmlns="https://github.com/avaloniaui"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:local="clr-namespace:UndertaleModTool"
                       xmlns:undertale="clr-namespace:UndertaleModLib.Models;assembly=UndertaleModLib"
                       xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
                       mc:Ignorable="d"
                       d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <local:NullToVisibilityConverter x:Key="VisibleIfNotNull" nullValue="False" notNullValue="True" />
    </UserControl.Resources>
    <Grid ColumnDefinitions="1*,3*">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="3" Text="Name" />
        <local:UndertaleStringReference Grid.Row="0" Grid.Column="1" Margin="3" ObjectReference="{Binding Name}" />

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="3" Text="Locals count" />
        <local:TextBoxDark Grid.Row="1" Grid.Column="1" Margin="3" Text="{Binding LocalsCount}" />

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="3" Text="Arguments count" />
        <local:TextBoxDark Grid.Row="2" Grid.Column="1" Margin="3" Text="{Binding ArgumentsCount}" />

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="3" Text="Offset" />
        <local:TextBoxDark Grid.Row="3" Grid.Column="1" Margin="3" Text="{Binding Offset}" />

        <TextBlock Grid.Row="4" Grid.Column="0" Margin="3" Text="Parent entry" IsVisible="{Binding ParentEntry, Converter={StaticResource VisibleIfNotNull}}" />
        <local:UndertaleObjectReference Grid.Row="4" Grid.Column="1" Margin="3" IsVisible="{Binding ParentEntry, Converter={StaticResource VisibleIfNotNull}}" ObjectReference="{Binding ParentEntry}" ObjectType="{x:Type undertale:UndertaleCode}" CanRemove="False" CanChange="False" />

        <TabControl x:Name="CodeModeTabs" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header="Decompiled" Name="DecompiledTab">
                <ae:TextEditor FontFamily="Consolas" Name="DecompiledEditor" IsReadOnly="True"
                               Background="#222222" LineNumbersForeground="#DBDBDB" Foreground="#C0C0C0"
                               ShowLineNumbers="True" WordWrap="True" FontSize="13" Padding="4" />
            </TabItem>
            <TabItem Header="Disassembly" Name="DisassemblyTab">
                <ae:TextEditor FontFamily="Consolas" Name="DisassemblyEditor" IsReadOnly="True"
                               Background="#222222" Foreground="#C0C0C0" WordWrap="True" FontSize="13" Padding="4" />
            </TabItem>
        </TabControl>
    </Grid>
</local:DataUserControl>
